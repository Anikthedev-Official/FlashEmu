<?xml version="1.0.0" encoding='utf-8'?>
<widget id="com.mustakim.flash" version="0.0.4" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>BlackHat Pro</name>
    <description>
        Flash emulator for playing simple games and animations. Built with Cordova and JavaScript, it provides a nostalgic experience for Flash content on modern platforms.
    </description>
    <author email="dev@cordova.apache.org" href="https://cordova.apache.org">
        Mustakim Rahman
    </author>
    <content src="index.html" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-navigation href="*" />
    <preference name="Orientation" value="landscape" />
    <preference name="Fullscreen" value="true" />
    <!-- regular icons as fallback -->
    <icon density="ldpi"    src="resources/android/icon/drawable-ldpi-icon.png" />
    <icon density="mdpi"    src="resources/android/icon/drawable-mdpi-icon.png" />
    <icon density="hdpi"    src="resources/android/icon/drawable-hdpi-icon.png" />
    <icon density="xhdpi"   src="resources/android/icon/drawable-xhdpi-icon.png" />
    <icon density="xxhdpi"  src="resources/android/icon/drawable-xxhdpi-icon.png" />
    <icon density="xxxhdpi" src="resources/android/icon/drawable-xxxhdpi-icon.png" />

    <!-- adaptive icon files -->
    <resource-file src="resources/android/xml/adaptive_icon.xml"
                   target="app/src/main/res/mipmap-anydpi-v26/ic_launcher.xml" />
    <resource-file src="resources/android/xml/adaptive_icon.xml"
                   target="app/src/main/res/mipmap-anydpi-v26/ic_launcher_round.xml" />
    <resource-file src="resources/android/values/colors.xml"
                   target="app/src/main/res/values/ic_launcher_colors.xml" />
    <resource-file src="resources/android/icon/drawable-xxxhdpi-icon.png"
                   target="app/src/main/res/mipmap-xxxhdpi/ic_launcher_foreground.png" />
</platform>
</widget>
